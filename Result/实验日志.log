[10:00] 开始补写 ifetc32.v（取指单元）：

  将第32-33行从乱码 "������" 替换为：
    assign PC_plus_4[31:2] = PC[31:2] + 1'b1;
    assign PC_plus_4[1:0]  = 2'b00;

  将第38-40行替换为 next_PC 优先级逻辑：
    if (Jrn == 1'b1)
        next_PC = Read_data_1;
    else if (Branch == 1'b1 && Zero == 1'b1)
        next_PC = Add_result;
    else if (nBranch == 1'b1 && Zero == 1'b0)
        next_PC = Add_result;
    else if (Jmp == 1'b1)
        next_PC = {PC_plus_4[31:28], Instruction[25:0], 2'b00};
    else if (Jal == 1'b1)
        next_PC = {PC_plus_4[31:28], Instruction[25:0], 2'b00};
    else
        next_PC = PC_plus_4;

  将第43-45行替换为 PC 寄存器逻辑（下降沿更新）：
    always @(negedge clock) begin
        if (reset == 1'b1) begin
            PC <= 32'h00000000;
            opcplus4 <= 32'h00000000;
        end else begin
            PC <= next_PC;
            opcplus4 <= PC_plus_4;
        end
    end

  学习发现：J 和 JAL 的跳转地址计算公式完全一样：
    next_PC = {PC_plus_4[31:28], Instruction[25:0], 2'b00}
  区别只有 JAL 额外保存 PC+4 到 $ra（用于返回）。PC 用下降沿更新是因为
  原模板设计约定如此，上升沿写寄存器、下降沿更新 PC，避免同一周期内冲突。

[10:45] 补写 idecode32.v（译码单元）：

  将第32-36行的 "������" 替换为：
    assign read_register_1_address = Instruction[25:21];   // rs
    assign read_register_2_address = Instruction[20:16];   // rt
    assign write_register_address_1 = Instruction[15:11];  // rd (R型)
    assign write_register_address_0 = Instruction[20:16];  // rt (I型)
    assign Instruction_immediate_value = Instruction[15:0];

  将第41-42行替换为：
    assign sign = Instruction[15];
    assign Sign_extend[31:0] = {{16{sign}}, Instruction_immediate_value};

  将第44-45行替换为：
    assign read_data_1 = register[read_register_1_address];
    assign read_data_2 = register[read_register_2_address];

  第47-49行 目标寄存器选择：
    always @* begin
        if (RegDst == 1'b1)
            write_register_address = write_register_address_1;  // rd
        else
            write_register_address = write_register_address_0;  // rt
    end

  第51-53行 写回数据三路选择：
    always @* begin
        if (Jal == 1'b1)
            write_data = opcplus4;          // JAL: 返回地址
        else if (MemtoReg == 1'b1)
            write_data = read_data;          // LW: 内存数据
        else
            write_data = ALU_result;         // 其他: ALU结果
    end

  第61行 寄存器写使能补完：
    if (write_register_address != 5'b00000)
        register[write_register_address] <= write_data;

**严重潜伏 Bug #6 在此引入（见后文详细分析）**：
  目标寄存器选择用了 RegDst=1→rd, RegDst=0→rt 的二选一。
  JAL 指令无 rd 无 rt 字段，MIPS 规定隐式写 $31($ra)。
  但 RegDst=0 时选了 instruction[20:16]（跳转目标地址的其中 5 位）作为目标寄存器号！
  幸运的是测试程序的 JAL 目标地址 bit[20:16] 恰好全为 0 → 指向 $0 → 写保护生效，
  数据写入被 $0 丢弃。这个 Bug 在仿真中完全不可见！直到人工审查才被发现。

[11:30] 补写 control32.v（控制器）：

  原始模板中 R_format 和 ALUOp 是完整的，其余 10 个 assign 全是 "����������"。

  将各 assign 替换为实际译码逻辑：
    assign I_format = (Opcode[5:3] == 3'b001) ? 1'b1 : 1'b0;
    assign Lw  = (Opcode == 6'b100011) ? 1'b1 : 1'b0;
    assign Jal = (Opcode == 6'b000011) ? 1'b1 : 1'b0;
    assign Jrn = (R_format && Function_opcode == 6'b001000) ? 1'b1 : 1'b0;
    assign RegWrite = (R_format || I_format || Lw || Jal) ? 1'b1 : 1'b0;
    assign Sw   = (Opcode == 6'b101011) ? 1'b1 : 1'b0;
    assign ALUSrc  = (I_format || Lw || Sw) ? 1'b1 : 1'b0;
    assign Branch  = (Opcode == 6'b000100) ? 1'b1 : 1'b0;
    assign nBranch = (Opcode == 6'b000101) ? 1'b1 : 1'b0;
    assign Jmp  = (Opcode == 6'b000010) ? 1'b1 : 1'b0;
    assign MemWrite = Sw;
    assign MemtoReg = Lw;
    assign Sftmd = (R_format && Function_opcode[5:3] == 3'b000) ? 1'b1 : 1'b0;

**严重潜伏 Bug #7 在此引入（见后文详细分析）**：
  RegWrite = (R_format || I_format || Lw || Jal)
  JR 指令 opcode=000000 → R_format=1 → RegWrite=1 ！
  但 JR 只跳转不写寄存器！幸好 JR 指令编码中 rd 字段恰好是 00000，
  写入目标为 $0，被写保护拦截了。

[13:00] 补写 executs32.v（执行单元）：

  第46-51行 移位操作补全：
    3'b000: Sinput = Binput << Shamt;                          // SLL
    3'b010: Sinput = Binput >> Shamt;                          // SRL
    3'b100: Sinput = Binput << Ainput[4:0];                    // SLLV
    3'b110: Sinput = Binput >> Ainput[4:0];                    // SRLV
    3'b011: Sinput = $signed(Binput) >>> Shamt;                // SRA
    3'b111: Sinput = $signed(Binput) >>> Ainput[4:0];          // SRAV

  第59行 SLT/SLTI 补全：
    ALU_Result = ($signed(Ainput) < $signed(Binput)) ? 32'd1 : 32'd0;

  第60行 LUI 补全：
    ALU_Result = {Binput[15:0], 16'b0};

  第61行 移位结果补全：
    ALU_Result = Sinput;

  第71-78行 ALU 8 种运算补全：
    3'b000: ALU_output_mux = Ainput & Binput;       // AND
    3'b001: ALU_output_mux = Ainput | Binput;       // OR
    3'b010: ALU_output_mux = Ainput + Binput;       // ADD/ADDI
    3'b011: ALU_output_mux = Ainput + Binput;       // ADDU
    3'b100: ALU_output_mux = Ainput ^ Binput;       // XOR
    3'b101: ALU_output_mux = ~(Ainput | Binput);    // NOR
    3'b110: ALU_output_mux = Ainput - Binput;       // SUB
    3'b111: ALU_output_mux = Ainput - Binput;       // SUBU

  学习发现：SRA（算术右移）用 `$signed(Binput) >>> Shamt`，高位填符号位；
  SRL（逻辑右移）用 `Binput >> Shamt`，高位填 0。Verilog 中 >> 和 >>> 的
  行为取决于左操作数是否声明为 signed。SRA 必须用 $signed() 包裹。

[14:00] 补写外设模块 — leds.v 和 switchs.v：

  leds.v（原始第17-19行为空壳）：
    always@(posedge led_clk or posedge ledrst) begin
        if (ledrst == 1'b1)
            ledout <= 24'h000000;
        else if (ledcs == 1'b1 && ledwrite == 1'b1) begin
            case (ledaddr)
                2'b00: ledout[15:0]  <= ledwdata;
                2'b01: ledout[23:16] <= ledwdata[7:0];
                default: ;
            endcase
        end
    end

  switchs.v（原始第16-18行为空壳）：
    always@(negedge switclk or posedge switrst) begin
        if (switrst == 1'b1)
            switchrdata <= 16'h0000;
        else if (switchcs == 1'b1 && switchread == 1'b1) begin
            case (switchaddr)
                2'b00: switchrdata <= switch_i[15:0];
                2'b01: switchrdata <= {8'b00000000, switch_i[23:16]};
                default: switchrdata <= 16'h0000;
            endcase
        end
    end

  LED 和 Switch 都是 24 位外设，但数据总线只有 16 位（ledwdata/switchrdata），
  所以分两次访问：addr[1:0]=00 访问低 16 位，addr[1:0]=01 访问高 8 位。

